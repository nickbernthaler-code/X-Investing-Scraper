# Copy this file to .env and fill in your real values
# NEVER commit .env to git — it contains secret keys

# Claude AI (Anthropic) - for re-analyzing investment ideas
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alpha Vantage - for real-time stock market data (free tier available)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# X (Twitter) API - for scraping posts (optional, $100/month)
# Leave blank to use mock data instead
X_BEARER_TOKEN=your_x_bearer_token_here

# Server port (default is 3000)
PORT=3000
